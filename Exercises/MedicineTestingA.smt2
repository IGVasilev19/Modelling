(declare-fun medicineAtRound (Int Int) Bool)

; Each round has exactly 3 medicines chosen
(assert (forall ((round Int))
  (implies (and (<= 1 round) (<= round 10))
    (= 3
      (+ (ite (medicineAtRound round 1) 1 0)
         (ite (medicineAtRound round 2) 1 0)
         (ite (medicineAtRound round 3) 1 0)
         (ite (medicineAtRound round 4) 1 0)
         (ite (medicineAtRound round 5) 1 0)
         (ite (medicineAtRound round 6) 1 0)
      )
    )
  )
))

; Each medicine appears in exactly 5 medicineAtRound
(assert (forall ((medicine Int))
  (implies (and (<= 1 medicine) (<= medicine 6))
    (= 5
      (+ (ite (medicineAtRound 1 medicine) 1 0)
         (ite (medicineAtRound 2 medicine) 1 0)
         (ite (medicineAtRound 3 medicine) 1 0)
         (ite (medicineAtRound 4 medicine) 1 0)
         (ite (medicineAtRound 5 medicine) 1 0)
         (ite (medicineAtRound 6 medicine) 1 0)
         (ite (medicineAtRound 7 medicine) 1 0)
         (ite (medicineAtRound 8 medicine) 1 0)
         (ite (medicineAtRound 9 medicine) 1 0)
         (ite (medicineAtRound 10 medicine) 1 0)
      )
    )
  )
))

; Any two distinct medicines appear together at most 2 times
(assert (forall ((medicine Int) (secondMedicine Int))
  (implies (and (<= 1 medicine) (<= medicine 6) (<= 1 secondMedicine) (<= secondMedicine 6) (not (= medicine secondMedicine)))
    (<= 2 
        (+ (ite (and (medicineAtRound 1 medicine) (medicineAtRound 1 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 2 medicine) (medicineAtRound 2 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 3 medicine) (medicineAtRound 3 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 4 medicine) (medicineAtRound 4 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 5 medicine) (medicineAtRound 5 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 6 medicine) (medicineAtRound 6 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 7 medicine) (medicineAtRound 7 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 8 medicine) (medicineAtRound 8 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 9 medicine) (medicineAtRound 9 secondMedicine)) 1 0)
           (ite (and (medicineAtRound 10 medicine) (medicineAtRound 10 secondMedicine)) 1 0)
        )
    )
  )
))

(check-sat)
